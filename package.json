{
  "name": "altrugenix-monorepo",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -At run build",
    "dev:ui": "yarn workspace @altrugenix/ui dev",
    "build:lib": "yarn workspace @altrugenix/ui build",
    "dev:docs": "yarn workspace altrugenix-docs dev",
    "build:docs": "yarn workspace altrugenix-docs build",
    "build:storybook": "storybook build",
    "dev:storybook": "storybook dev -p 6006",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspaces foreach -A run test",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "build:all": "yarn build && yarn build:docs && yarn build:storybook",
    "change": "changeset",
    "version:ci": "changeset version",
    "release": "changeset publish",
    "release:github": "changeset publish",
    "log:test": "yarn test > test.log 2>&1 || grep -iE \"stderr\" test.log",
    "log:type-check": "yarn type-check > type-check.log 2>&1 || grep -E \"error TS|TS[0-9]+|Cannot|not assignable|found|expected\" type-check.log",
    "log:lint": "yarn lint > lint.log 2>&1 || grep -E \"error|Error|✖\" lint.log",
    "log:build": "yarn build > build.log 2>&1 || grep -iE 'fail|error|✕' build.log",
    "log:all": "yarn format && yarn log:lint && yarn log:type-check && yarn log:test && yarn log:build"
  },
  "dependencies": {
    "prettier": "^3.8.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.6",
    "framer-motion": "^12.38.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.13.0"
}
