{
  "name": "altrugenix-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "yarn workspace @altrugenix/ui build",
    "dev:ui": "yarn workspace @altrugenix/ui dev",
    "dev:demo": "yarn workspace altrugenix-demo dev",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspaces run test"
  }
}
