{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@altrugenix/core": ["../core/src"],
      "@altrugenix/accordion": ["../accordion/src"],
      "@altrugenix/aspect-ratio": ["../aspect-ratio/src"],
      "@altrugenix/avatar": ["../avatar/src"],
      "@altrugenix/badge": ["../badge/src"],
      "@altrugenix/button": ["../button/src"],
      "@altrugenix/calendar": ["../calendar/src"],
      "@altrugenix/carousel": ["../carousel/src"],
      "@altrugenix/checkbox": ["../checkbox/src"],
      "@altrugenix/dialog": ["../dialog/src"],
      "@altrugenix/icon": ["../icon/src"],
      "@altrugenix/input": ["../input/src"],
      "@altrugenix/kanban": ["../kanban/src"],
      "@altrugenix/label": ["../label/src"],
      "@altrugenix/menu": ["../menu/src"],
      "@altrugenix/popover": ["../popover/src"],
      "@altrugenix/progress": ["../progress/src"],
      "@altrugenix/radio": ["../radio/src"],
      "@altrugenix/select": ["../select/src"],
      "@altrugenix/slider": ["../slider/src"],
      "@altrugenix/snackbar": ["../snackbar/src"],
      "@altrugenix/switch": ["../switch/src"],
      "@altrugenix/table": ["../table/src"],
      "@altrugenix/textarea": ["../textarea/src"],
      "@altrugenix/toast": ["../toast/src"],
      "@altrugenix/virtual-list": ["../virtual-list/src"],
      "@altrugenix/chip": ["../chip/src"],
      "@altrugenix/link": ["../link/src"]
    }
  },
  "include": ["src"]
}
